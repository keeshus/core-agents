{
  "name": "core-agents",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "worker",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"backend,worker,frontend\" -c \"blue,green,magenta\" \"npm run backend:dev\" \"wait-on http://localhost:3001/api/health && npm run worker:dev\" \"wait-on http://localhost:3001/api/health && npm run frontend:dev\"",
    "backend": "npm run start -w backend",
    "backend:dev": "tsx watch --env-file=.env backend/src/index.ts",
    "backend:build": "npm run build -w backend",
    "worker": "npm run start -w worker",
    "worker:dev": "tsx watch --env-file=.env worker/src/run.ts",
    "worker:build": "npm run build -w worker",
    "frontend:dev": "npm run dev -w frontend",
    "frontend:build": "npm run build -w frontend",
    "frontend:start": "npm run start -w frontend -- -H 0.0.0.0",
    "shared:typecheck": "npm run typecheck -w shared",
    "db:generate": "npm run db:generate -w backend",
    "db:migrate": "npm run db:migrate -w backend",
    "db:push": "cd backend && drizzle-kit push",
    "test:e2e:up": "docker compose -f docker-compose.e2e.yml up -d --wait",
    "test:e2e:down": "docker compose -f docker-compose.e2e.yml down -v --timeout 10",
    "test:e2e:db-setup": "cd backend && DATABASE_URL=postgres://coreagents:coreagents@localhost:5432/coreagents npx drizzle-kit push --config drizzle.config.ts",
    "test:e2e:run": "playwright test --config frontend/playwright.config.ts",
    "test:e2e": "npm run test:e2e:up && npm run test:e2e:db-setup && npm run test:e2e:run && npm run test:e2e:down"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "wait-on": "^9.0.10"
  },
  "type": "module"
}
